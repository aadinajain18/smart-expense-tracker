# =============================================================
# Smart Expense Tracker — Frontend Environment Variables
# =============================================================
# Copy this file to .env.local for local development.
# For Vercel production, add these in the Vercel Dashboard under
# Project Settings → Environment Variables.
# =============================================================

# --- Backend API URL ---
# Leave EMPTY for local development (Vite proxy handles it automatically).
# Set to your deployed Render backend URL for production.
# Example: https://smart-expense-backend.onrender.com
# DO NOT add a trailing slash.
VITE_API_URL=
