# ===============================================================
# Smart Expense Tracker — Backend Environment Variables
# ===============================================================
# Copy this to .env and fill in real values.
# NEVER commit .env to Git.
# ===============================================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
# Get this from: Atlas Dashboard → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/smart-expense-tracker?retryWrites=true&w=majority

# JWT
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string

# Frontend URL (for CORS in production — no trailing slash)
FRONTEND_URL=https://your-app.vercel.app

# OpenAI (optional — AI insights/chatbot work offline without this)
OPENAI_API_KEY=your_openai_api_key_here
